<%- include('../partials/header') %>

<main class="maintenance-form-page">
    <div class="form-card">
        <header class="form-header">
            <h1>New Maintenance Request</h1>
            <p>Please describe the issue in detail. We will notify you once a manager is assigned.</p>
        </header>

        <form action="/maintenance/create" method="POST" class="styled-form">
            <div class="form-group">
                <label for="title">Issue Summary</label>
                <input type="text" id="title" name="title" placeholder="e.g., HVAC not cooling" required>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="unitId">Unit ID</label>
                    <input type="number" id="unitId" name="unitId" placeholder="101" required>
                </div>

                <div class="form-group">
                    <label for="priority">Priority</label>
                    <select id="priority" name="priority">
                        <option value="low">Low</option>
                        <option value="medium" selected>Medium</option>
                        <option value="high">High</option>
                        <option value="emergency">Emergency</option>
                    </select>
                </div>
            </div>

            <div class="form-group">
                <label for="description">Detailed Description</label>
                <textarea id="description" name="description" rows="5" placeholder="Explain the location and nature of the problem..." required></textarea>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-primary-sm">Submit Request</button>
                <a href="/maintenance" class="btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</main>

<%- include('../partials/footer') %>