<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Havn</title>
    <%- renderStyles() %>
    <% if (locals.stylesheet) { %>
        <link rel="stylesheet" href="/css/<%= stylesheet %>">
    <% } %>
    </head>

<body class="default-body">
    <header class="main-header">
        <nav class="nav-container">
            <div class="logo">
                <a href="/"><strong>HAVN</strong></a>
            </div>
            
            <ul class="nav-links">
                <li><a href="/">Home</a></li>
                <li><a href="/properties">Properties</a></li>
                <li><a href="/about">About</a></li>
                <li><a href="/contact">Contact Us</a></li>

                <% if (isLoggedIn) { %>
                    <li><a href="/dashboard">Dashboard</a></li>

                    <% if (user.role === 'admin' || user.role === 'manager') { %>
                        <li><a href="/maintenance">Maintenance Requests</a></li>
                        <li><a href="/contact/responses">Contact Responses</a></li>
                    <% } %>
                        
                    <% if (user.role === 'admin') { %>
                        <li><a href="/applications">Applications</a></li>
                        <li><a href="/register/list">All Users</a></li>
                    <% } %>

                    <li><a href="/logout">Logout</a></li>

                <% } else { %>
                    <li><a href="/login">Login</a></li>
                    <li class="auth-link"><a href="/register" class="btn-primary-sm">Join Havn</a></li>
                <% } %>
            </ul>
        </nav>
    </header>
    <% 
        const messages = flash();
        const hasMessages = Object.values(messages).some(arr => arr.length > 0);
    %>
    <% if (hasMessages) { %>
        <div class="flash-messages">
            <% Object.keys(messages).forEach(type => { %>
                <% messages[type].forEach(message => { %>
                    <div class="flash <%= type %>">
                        <%= message %>
                    </div>
                <% }); %>
            <% }); %>
        </div>
    <% } %>
  