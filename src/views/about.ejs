<%- include('partials/header') %>

<main class="about-page">
    <section class="hero-section">
        <div class="container">
            <h1>Welcome to Havn</h1>
            <p class="hero-subtitle">Redefining the standard of property management through transparency, design, and care.</p>
        </div>
    </section>

    <section class="story-section">
        <div class="container flex-row">
            <div class="story-content">
                <h2>Our Story</h2>
                <p>Finding a place to call home shouldn't be a source of stress. At <strong>Havn</strong>, we believe that property management is about more than just maintaining buildings—it’s about cultivating environments where people can truly settle in and exhale.</p>
                <p>Founded on the principles of transparency and human-centric service, Havn was created to bridge the gap between property owners and residents through seamless technology and proactive care.</p>
            </div>
            <div class="story-image">
                <div class="image-placeholder">Our Philosophy in Motion</div>
            </div>
        </div>
    </section>

    <section class="values-section">
        <div class="container grid-4">
            <div class="value-card">
                <h3>Transparency</h3>
                <p>Real-time reporting and open channels so you’re never in the dark.</p>
            </div>
            <div class="value-card">
                <h3>Proactive Care</h3>
                <p>We don't wait for things to break. We maintain properties at peak value.</p>
            </div>
            <div class="value-card">
                <h3>Modern Living</h3>
                <p>Digital lease signing and instant requests to make life simpler.</p>
            </div>
            <div class="value-card">
                <h3>Community</h3>
                <p>We treat every property as a neighborhood asset, benefiting everyone.</p>
            </div>
        </div>
    </section>

    <section class="advantage-section">
        <div class="container">
            <h2>The Havn Advantage</h2>
            <div class="table-container">
                <table class="advantage-table">
                    <thead>
                        <tr>
                            <th>For Property Owners</th>
                            <th>For Our Residents</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Maximized ROI & Low Vacancy</td>
                            <td>24/7 Support for Urgent Inquiries</td>
                        </tr>
                        <tr>
                            <td>Vetted Background & Credit Screening</td>
                            <td>User-friendly Digital Payment Portal</td>
                        </tr>
                        <tr>
                            <td>Complete Legal & Housing Compliance</td>
                            <td>Curated, Safe, and Ready-to-Live Spaces</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </section>

    <section class="cta-section">
        <div class="container">
            <h2>Ready to find your Havn?</h2>
            <p>Let us take the weight off your shoulders.</p>
            <a href="/contact" class="cta-button">Get in Touch</a>
        </div>
    </section>
</main>

<%- include('partials/footer') %>