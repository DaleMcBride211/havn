<%- include('../../partials/header') %>

<main class="contact-list-container">
    <div class="list-header">
        <h1><%= title %></h1>
        <div class="count-badge"><%= contacts.length %> Inquiries</div>
    </div>

    <div class="table-wrapper">
        <table class="contact-table">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Subject</th>
                    <th>Property</th>
                    <th>Status</th>
                    <th>Action</th> </tr>
            </thead>
            <tbody>
                <% if (contacts.length > 0) { %>
                    <% contacts.forEach(contact => { %>
                        <tr class="status-<%= contact.status %>">
                            <td class="cell-date">
                                <%= new Date(contact.created_at).toLocaleDateString() %>
                            </td>
                            <td class="cell-name">
                                <%= contact.first_name %> <%= contact.last_name %>
                            </td>
                            <td class="cell-email">
                                    <%= contact.email %>
                            </td>
                            <td class="cell-phone"><%= contact.phone %></td>
                            <td class="cell-subject"><%= contact.subject %></td>
                            <td class="cell-property">
                                <%= contact.property_id || 'N/A' %>
                            </td>
                            <td class="cell-status">
                                <span class="status-tag"><%= contact.status %></span>
                            </td>
                            <td class="cell-action">
                                <a href="/contact/responses/<%= contact.id %>" class="btn-detail">View Details</a>
                            </td>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr>
                        <td colspan="8" class="empty-row">No inquiries found.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</main>

<%- include('../../partials/footer') %>